# More info see https://www.yuque.com/yunyoujun/notes/oh-my-zsh
# oh-my-zsh template: https://github.com/ohmyzsh/ohmyzsh/blob/master/templates/zshrc.zsh-template
# --------

typeset -U path PATH

_path_prepend() {
  [[ -d "$1" ]] && path=("$1" "${path[@]}")
}

_path_append() {
  [[ -d "$1" ]] && path+=("$1")
}

_is_interactive_tty() {
  [[ -o interactive && -t 0 && -t 1 ]]
}

# Homebrew initialization
if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

# ---- Oh My Zsh ----

export ZSH="${ZSH:-$HOME/.oh-my-zsh}"
export ZSH_CUSTOM="${ZSH_CUSTOM:-$ZSH/custom}"

# Updates: auto-check every two weeks.
zstyle ':omz:update' mode auto
zstyle ':omz:update' frequency 14

HIST_STAMPS="yyyy-mm-dd"
COMPLETION_WAITING_DOTS="true"

# Prompt
# Starship is the default prompt for new machines. Powerlevel10k remains a
# fallback for machines that already have it installed.
ZSH_THEME=""
if ! command -v starship >/dev/null 2>&1; then
  if [[ -d "$ZSH_CUSTOM/themes/powerlevel10k" ]]; then
    ZSH_THEME="powerlevel10k/powerlevel10k"
  else
    ZSH_THEME="robbyrussell"
  fi
fi

# Optional custom plugins:
# git clone https://github.com/zsh-users/zsh-autosuggestions ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-autosuggestions
# git clone https://github.com/zsh-users/zsh-syntax-highlighting.git ${ZSH_CUSTOM:-~/.oh-my-zsh/custom}/plugins/zsh-syntax-highlighting

# autojump https://github.com/wting/autojump
# macos: brew install autojump

plugins=()

for plugin in git node dotenv macos docker docker-compose; do
  [[ -d "$ZSH/plugins/$plugin" ]] && plugins+=("$plugin")
done

if [[ -d "$ZSH/plugins/autojump" ]] && { command -v autojump >/dev/null 2>&1 || [[ -r "${HOMEBREW_PREFIX:-/opt/homebrew}/etc/profile.d/autojump.sh" ]]; }; then
  plugins+=(autojump)
fi

for plugin in zsh-autosuggestions zsh-syntax-highlighting; do
  [[ -d "$ZSH_CUSTOM/plugins/$plugin" ]] && plugins+=("$plugin")
done
unset plugin

if [[ -r "$ZSH/oh-my-zsh.sh" ]]; then
  source "$ZSH/oh-my-zsh.sh"
fi

# Homebrew zsh plugins, used when they are not installed as Oh My Zsh custom plugins.
if [[ -n "${HOMEBREW_PREFIX:-}" ]]; then
  if [[ ! -d "$ZSH_CUSTOM/plugins/zsh-autosuggestions" && -r "$HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ]]; then
    source "$HOMEBREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
  fi
fi

# ---- User configuration ----

export VISUAL="${VISUAL:-buddycn}"
export EDITOR="${EDITOR:-$VISUAL}"

# fnm (fast node manager)
if command -v fnm >/dev/null 2>&1; then
  eval "$(fnm env --use-on-cd --shell zsh)"
fi

# pnpm
export PNPM_HOME="${PNPM_HOME:-$HOME/Library/pnpm}"
_path_prepend "$PNPM_HOME"

# bun
export BUN_INSTALL="${BUN_INSTALL:-$HOME/.bun}"
[[ -s "$BUN_INSTALL/_bun" ]] && source "$BUN_INSTALL/_bun"
_path_prepend "$BUN_INSTALL/bin"

# ruby
if [[ -n "${HOMEBREW_PREFIX:-}" ]]; then
  _path_prepend "$HOMEBREW_PREFIX/opt/ruby/bin"
fi

# android
export ANDROID_HOME="${ANDROID_HOME:-$HOME/Library/Android/sdk}"
_path_append "$ANDROID_HOME/platform-tools"

if [[ -n "${HOMEBREW_PREFIX:-}" && -d "$HOMEBREW_PREFIX/opt/openjdk@21" ]]; then
  export JAVA_HOME="${JAVA_HOME:-$HOMEBREW_PREFIX/opt/openjdk@21}"
fi

if [[ -d "$ANDROID_HOME/ndk" ]]; then
  ndk_versions=("$ANDROID_HOME"/ndk/*(N/))
  if (( ${#ndk_versions[@]} > 0 )); then
    export NDK_HOME="${NDK_HOME:-${ndk_versions[-1]}}"
  fi
  unset ndk_versions
fi

# envman
[[ -s "$HOME/.config/envman/load.sh" ]] && source "$HOME/.config/envman/load.sh"

# Additional PATH
_path_prepend "$HOME/.codebuddy/bin"            # CodeBuddy CN
_path_prepend "$HOME/.local/bin"                # CloudBase CLI
_path_prepend "$HOME/background_agent_cli/bin"  # background_agent_cli

# simple-git-hooks: ensure pnpm is in PATH for GUI git clients
export SIMPLE_GIT_HOOKS_RC="$HOME/.simple-git-hooks-rc"

# fzf
if _is_interactive_tty && command -v fzf >/dev/null 2>&1; then
  source <(fzf --zsh)
fi

# zoxide
if [[ -o interactive ]] && command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init zsh)"
fi

# prompt
if [[ -o interactive && "${TERM:-}" != "dumb" ]] && command -v starship >/dev/null 2>&1; then
  eval "$(starship init zsh)"
else
  # powerlevel10k fallback (installed via Homebrew)
  if [[ -z "$ZSH_THEME" ]]; then
    p10k_theme="${HOMEBREW_PREFIX:-/opt/homebrew}/share/powerlevel10k/powerlevel10k.zsh-theme"
    [[ -r "$p10k_theme" ]] && source "$p10k_theme"
    unset p10k_theme
  fi
  # To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
  [[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
fi

# ---- Aliases ----

# dev shortcuts (using ni toolchain)
alias build="nr build"
alias dev="nr dev"
alias lint="nr lint"
alias lintf="pnpm run lint --fix" # npm can not pass --fix
alias mock="nr mock"
alias serve="nr serve"
alias tc="nr typecheck"

# git
alias gcgithub="git config user.name 'YunYouJun' && git config user.email 'me@yunyoujun.cn'"
# git fetch & 工蜂
(( $+aliases[gf] )) && unalias gf

# tencent npm mirror
alias tnpm="pnpm i --registry=http://mirrors.tencent.com/npm/"

# for terminal proxy
# WSL use windows dns ip, see it by `cat /etc/resolv.conf`
# local use 127.0.0.1
# macos surge do not need it
alias goproxy="export https_proxy=http://127.0.0.1:8234;export http_proxy=http://127.0.0.1:8234;export all_proxy=socks5://127.0.0.1:8235"
alias disproxy="unset https_proxy;unset http_proxy;unset all_proxy"

# python
alias python2="$HOME/.pyenv/versions/2.7.18/bin/python2"

# ---- Secrets (managed by dotfiles sync) ----

_oa_pages_api_key="{{DOTFILES_SECRET:OA_PAGES_API_KEY}}"
if [[ "$_oa_pages_api_key" != "{{DOTFILES_SECRET:""OA_PAGES_API_KEY}}" ]]; then
  export OA_PAGES_API_KEY="$_oa_pages_api_key"
fi
unset _oa_pages_api_key

if [[ -n "${HOMEBREW_PREFIX:-}" ]]; then
  if [[ ! -d "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting" && -r "$HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]]; then
    source "$HOMEBREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
  fi
fi

unfunction _path_prepend _path_append _is_interactive_tty
