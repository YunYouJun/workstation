{
  "name": "@yunyoujun/workstation-repo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "build": "pnpm -r run build",
    "ci": "pnpm run vscode:extensions:check && pnpm run lint && pnpm run typecheck && pnpm test && pnpm run build && pnpm run docs:build",
    "dev": "pnpm -r run dev",
    "docs:build": "pnpm docs:generate && vitepress build docs",
    "docs:dev": "pnpm docs:generate && vitepress dev docs",
    "docs:generate": "tsx scripts/vscode-extensions.ts",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint .",
    "mcp": "tsx scripts/codex-mcp.ts",
    "mcp:check": "tsx scripts/codex-mcp.ts check",
    "mcp:install": "tsx scripts/codex-mcp.ts install",
    "mcp:list": "tsx scripts/codex-mcp.ts list",
    "mcp:status": "tsx scripts/codex-mcp.ts status",
    "release": "bumpp packages/cli/package.json && pnpm --filter @yunyoujun/workstation build",
    "secrets:scan": "gitleaks git --redact --verbose --no-banner",
    "skills": "tsx scripts/codex-skills.ts",
    "skills:check": "tsx scripts/codex-skills.ts check",
    "skills:install": "tsx scripts/codex-skills.ts install",
    "skills:list": "tsx scripts/codex-skills.ts list",
    "skills:status": "tsx scripts/codex-skills.ts status",
    "software": "tsx scripts/software.ts",
    "software:check": "pnpm software check",
    "software:install": "pnpm software install",
    "software:missing": "pnpm software missing",
    "software:open": "pnpm software open",
    "software:status": "pnpm software status",
    "projects:clone-active": "pnpm --filter @yunyoujun/workstation exec tsx src/cli.ts p active",
    "projects:status": "pnpm --filter @yunyoujun/workstation exec tsx src/cli.ts p status",
    "private": "pnpm --filter @yunyoujun/workstation exec tsx src/cli.ts private",
    "private:apply": "pnpm private apply",
    "private:check": "pnpm private check",
    "private:connect": "pnpm private connect",
    "private:file-restore": "pnpm private file-restore",
    "private:list": "pnpm private list",
    "private:mcp-export": "pnpm private mcp-export",
    "private:status": "pnpm private status",
    "sync": "pnpm --filter @yunyoujun/workstation exec tsx src/cli.ts df sync",
    "test": "pnpm -r run test",
    "typecheck": "tsc --noEmit && pnpm -r run typecheck",
    "vscode:extensions": "pnpm docs:generate",
    "vscode:extensions:check": "tsx scripts/vscode-extensions.ts check"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/simple-icons": "^1.2.88",
    "@shikijs/vitepress-twoslash": "^3.23.0",
    "@types/node": "^25.9.4",
    "@yunyoujun/docs": "^0.1.14",
    "bumpp": "^11.1.0",
    "changelogithub": "^14.0.0",
    "eslint": "^10.6.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "unocss": "^66.7.4",
    "unplugin-vue-components": "29.1.0",
    "vite": "7.3.0",
    "vitepress": "^1.6.4"
  }
}
