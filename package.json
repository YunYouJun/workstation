{
  "name": "@yunyoujun/workstation-repo",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.6.0",
  "scripts": {
    "build": "pnpm -r run build",
    "ci": "pnpm run lint && pnpm run typecheck && pnpm test && pnpm run build && pnpm run docs:build",
    "dev": "pnpm -r run dev",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "lint": "eslint .",
    "release": "bumpp packages/cli/package.json && pnpm --filter @yunyoujun/workstation build",
    "software": "tsx scripts/software.ts",
    "software:check": "tsx scripts/software.ts check",
    "software:install": "tsx scripts/software.ts install",
    "software:missing": "tsx scripts/software.ts missing",
    "software:open": "tsx scripts/software.ts open",
    "software:status": "tsx scripts/software.ts status",
    "projects:clone-active": "pnpm --filter @yunyoujun/workstation exec tsx src/cli.ts p active",
    "projects:status": "pnpm --filter @yunyoujun/workstation exec tsx src/cli.ts p status",
    "sync": "pnpm --filter @yunyoujun/workstation exec tsx src/cli.ts df sync",
    "test": "pnpm -r run test",
    "typecheck": "tsc --noEmit && pnpm -r run typecheck"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@iconify-json/logos": "^1.2.11",
    "@iconify-json/simple-icons": "^1.2.88",
    "@shikijs/vitepress-twoslash": "^3.20.0",
    "@types/node": "^25.9.3",
    "@yunyoujun/docs": "^0.1.14",
    "bumpp": "^11.1.0",
    "changelogithub": "^14.0.0",
    "eslint": "^10.5.0",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "unocss": "^66.5.10",
    "unplugin-vue-components": "29.1.0",
    "vite": "7.3.0",
    "vitepress": "^1.6.4"
  }
}
