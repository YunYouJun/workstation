{
  "name": "@yunyoujun/workstation",
  "type": "module",
  "version": "0.1.0",
  "description": "CLI tool for workstation automation and dotfiles sync",
  "author": "YunYouJun <me@yunyoujun.cn>",
  "license": "MIT",
  "homepage": "https://github.com/YunYouJun/workstation",
  "repository": {
    "type": "git",
    "url": "https://github.com/YunYouJun/workstation",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "workstation",
    "dotfiles",
    "cli",
    "sync"
  ],
  "bin": {
    "dotfiles": "./dist/cli.js",
    "workstation": "./dist/cli.js",
    "wst": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json"
  },
  "dependencies": {
    "@clack/prompts": "^1.7.0",
    "cac": "^7.0.0",
    "consola": "^3.4.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.5",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
