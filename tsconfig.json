{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": [
    "software.config.ts",
    "vscode.extensions.config.ts",
    "scripts/**/*.ts",
    "docs/.vitepress/**/*.ts"
  ]
}
